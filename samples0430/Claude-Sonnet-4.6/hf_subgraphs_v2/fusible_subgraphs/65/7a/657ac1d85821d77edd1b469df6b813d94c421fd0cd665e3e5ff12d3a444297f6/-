* 3-D grid  (B, C, ceil(HW/BLOCK_SIZE))  — channel index comes for free from
  program_id(1), eliminating per-element integer div/mod.
* Gamma / BN-params are scalar loads (one float per program, broadcast to the
  entire block) instead of per-element gathers.
* Autotune keyed on HW so the best BLOCK_SIZE is chosen per spatial resolution.
"""

import torch
import triton
import triton.language as tl


# ---------------------------------------------------------------------------
# Kernel 1 – fuse dropout(p=0) + layer-scale * + residual add  →  tmp10
#   grid : (B, C, ceil(HW / BLOCK_SIZE))
# ---------------------------------------------------------------------------

@triton.autotune(
    configs=[
        triton.Config({'BLOCK_SIZE': 4096}, num_warps=16, num_stages=4),
    ],
    key=['HW', 'B'],
)
@triton.jit
def _scale_add_kernel(
    conv_out_ptr,  # [B, C, H, W]  (NCHW, contiguous)
    gamma_ptr,     # [C, 1, 1]  → C contiguous floats (stride-0 broadcast dim)
    residual_ptr,  # [B, C, H, W]
    out_ptr,       # [B, C, H, W]  out = residual + conv_out * gamma
    HW,            # H * W  (spatial elements per (batch, channel) pair)
    C,             # number of channels  (needed to compute flat base offset)
    B,             # batch size  (used as autotune key; grid dim-0 encodes this)
    BLOCK_SIZE: tl.constexpr,
):
    # 3-D grid: dim-0 = batch b, dim-1 = channel c, dim-2 = spatial block bid
    b   = tl.program_id(0)
    c   = tl.program_id(1)
    bid = tl.program_id(2)

    # Flat base for the (b, c) pair in NCHW layout: b*C*HW + c*HW
    base    = (b * C + c) * HW + bid * BLOCK_SIZE
    offsets = base + tl.arange(0, BLOCK_SIZE)

    # Mask: only process elements within this (b, c) channel slice
    inner = bid * BLOCK_SIZE + tl.arange(0, BLOCK_SIZE)
    mask  = inner < HW

    # Gamma: scalar load for channel c  (no gather, no per-element index)
    g = tl.load(gamma_ptr + c).to(tl.float32)

    co_raw  = tl.load(conv_out_ptr + offsets, mask=mask, other=0.0)
    res_raw = tl.load(residual_ptr + offsets, mask=mask, other=0.0)

    co  = co_raw.to(tl.float32)
    res = res_raw.to(tl.float32)

    # dropout(p=0, training=False) = identity → skipped
    result = res + co * g

    tl.store(out_ptr + offsets, result.to(co_raw.dtype), mask=mask)


# ---------------------------------------------------------------------------
# Kernel 2 – batch-norm inference  →  tmp11
#   grid : (B, C, ceil(HW / BLOCK_SIZE))
# ---------------------------------------------------------------------------

@triton.autotune(
    configs=[
        triton.Config({'BLOCK_SIZE': 256},  num_warps=2),
        triton.Config({'BLOCK_SIZE': 512},  num_warps=4),
        triton.Config({'BLOCK_SIZE': 1024}, num_warps=4),
        triton.Config({'BLOCK_SIZE': 1024}, num_warps=8),
        triton.Config({'BLOCK_SIZE': 2048}, num_warps=8),
        triton.Config({'BLOCK_SIZE': 4096}, num_warps=16),
    ],
    key=['HW'],
)
@triton.jit
def _bn_infer_kernel(
    x_ptr,         # [B, C, H, W]
    mean_ptr,      # [C]
    var_ptr,       # [C]
    weight_ptr,    # [C]
    bias_ptr,      # [C]
    out_ptr,       # [B, C, H, W]
    HW,            # H * W
    C,             # channels
    BLOCK_SIZE: tl.constexpr,
):
    b   = tl.program_id(0)
    c   = tl.program_id(1)
    bid = tl.program_id(2)

    base    = (b * C + c) * HW + bid * BLOCK_SIZE
    offsets = base + tl.arange(0, BLOCK_SIZE)
    inner   = bid * BLOCK_SIZE + tl.arange(0, BLOCK_SIZE)
    mask    = inner < HW

    # Per-channel scalars (one load each, broadcast over the block)
    mu  = tl.load(mean_ptr   + c).to(tl.float32)
    va  = tl.load(var_ptr    + c).to(tl.float32)
    bw  = tl.load(weight_ptr + c).to(tl.float32)
    bb  = tl.load(bias_ptr   + c).to(tl.float32)

    x_raw = tl.load(x_ptr + offsets, mask=mask, other=0.0)
    x     = x_raw.to(tl.float32)

    # Fuse into two FMAs: out = x * scale + shift
    inv_std = tl.rsqrt(va + 1e-5)
    scale   = inv_std * bw
    shift   = bb - mu * scale
    result  = x * scale + shift

    tl.store(out_ptr + offsets, result.to(x_raw.dtype), mask=mask)


# ---------------------------------------------------------------------------
# Shared @torch.fx.wrap dispatch  (MUST be the identical object in every pass)
# Inlined wrappers to minimise Python call-stack depth.
# ---------------------------------------------------------------------------

@torch.fx.wrap
def fused_dispatch(*args):
    """
    Route-based dispatch.  args[-1] is always the string route key.
    """
    if args[-1] == "scale_add":
        # args: conv_out, gamma, residual, "scale_add"
        conv_out, gamma, residual = args[0], args[1], args[2]
        B, C, H, W = conv_out.shape
        HW  = H * W
        out = torch.empty_like(conv_out)
        grid = lambda meta: (B, C, triton.cdiv(HW, meta['BLOCK_SIZE']))
        _scale_add_kernel[grid](conv_out, gamma, residual, out, HW, C, B)
        return out

    # route == "bn_infer"
    # args: x, mean, var, weight, bias, "bn_infer"
    x, bn_mean, bn_var, bn_weight, bn_bias = (
        args[0], args[1], args[2], args[3], args[4]
    )
    B, C, H, W = x.shape
    HW  = H * W
    out = torch.empty_like(x)
    grid = lambda meta: (B, C, triton.cdiv(HW, meta['BLOCK_SIZE']))
    _bn_infer_kernel[grid](x, bn_mean, bn_var, bn_weight, bn_bias, out, HW, C)
    return out